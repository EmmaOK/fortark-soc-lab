# Local Suricata rules — lab-specific detections

# Test rule — triggers on curl to testmynids.org (smoke test)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"TESTING Suricata alert test - testmynids.org"; flow:established,to_server; http.host; content:"testmynids.org"; classtype:policy-violation; sid:9000001; rev:1;)

# Detect outbound connections to common C2 ports
alert tcp $HOME_NET any -> $EXTERNAL_NET [4444,4445,5555,6666,7777,8888,9999,31337] (msg:"SUSPICIOUS Outbound connection to common C2 port"; flow:established,to_server; classtype:trojan-activity; sid:9000002; rev:1;)

# Detect DNS queries for long random subdomains (possible DGA)
alert dns any any -> any 53 (msg:"SUSPICIOUS Long random subdomain DNS query (possible DGA)"; dns.query; pcre:"/^[a-z0-9]{20,}\./"; classtype:bad-unknown; sid:9000003; rev:1;)

# Lab 2 sim: exfil POST to httpbin.org (T1041)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Lab2 Sim: Data exfiltration POST to httpbin.org"; flow:established,to_server; http.method; content:"POST"; http.host; content:"httpbin.org"; classtype:data-loss; sid:9000010; rev:1;)

# Lab 5 sim: supply chain C2 callback (T1071.001)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Lab5 Sim: Supply chain C2 callback to httpbin.org"; flow:established,to_server; http.method; content:"POST"; http.host; content:"httpbin.org"; classtype:trojan-activity; sid:9000011; rev:1;)
