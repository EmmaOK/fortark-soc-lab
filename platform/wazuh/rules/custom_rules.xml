<group name="custom_soc,lab_simulation,">

  <!-- Brute force detection: 6+ failed SSH auths in 2 minutes -->
  <rule id="100020" level="10" frequency="6" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip/>
    <description>Brute force attack detected: $(data.srcip) → $(agent.name)</description>
    <group>authentication_failures,pci_dss_11.4,gdpr_IV_35.7.d,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Suricata high-severity alert forwarded via Filebeat -->
  <rule id="100030" level="8">
    <if_sid>31100</if_sid>
    <match>suricata</match>
    <field name="alert.severity">1</field>
    <description>Suricata high-severity IDS alert: $(alert.signature)</description>
    <group>network_ids,suricata,</group>
  </rule>

  <!-- ── Lab 2: Post-exploitation sim ────────────────────────────────── -->

  <rule id="100200" level="5">
    <program_name>^lab2-attacker$</program_name>
    <match>DISCOVERY</match>
    <description>Lab 2 Sim: System discovery — attacker enumerating system information</description>
    <mitre>
      <id>T1082</id>
      <id>T1033</id>
    </mitre>
    <group>lab2,discovery,attack_simulation,</group>
  </rule>

  <rule id="100201" level="5">
    <program_name>^lab2-attacker$</program_name>
    <match>RECON</match>
    <description>Lab 2 Sim: Network reconnaissance — open connections and interfaces enumerated</description>
    <mitre>
      <id>T1049</id>
      <id>T1016</id>
    </mitre>
    <group>lab2,recon,attack_simulation,</group>
  </rule>

  <!-- ── Lab 4: Ransomware sim ─────────────────────────────────────────── -->

  <rule id="100400" level="6">
    <program_name>^lab4-ransomware$</program_name>
    <match>STAGE:DISCOVERY</match>
    <description>Lab 4 Sim: Ransomware scanning filesystem for encryptable files</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>lab4,ransomware,discovery,attack_simulation,</group>
  </rule>

  <rule id="100401" level="8">
    <program_name>^lab4-ransomware$</program_name>
    <match>STAGE:ENCRYPT</match>
    <description>Lab 4 Sim: Ransomware mass encryption started</description>
    <mitre>
      <id>T1486</id>
    </mitre>
    <group>lab4,ransomware,impact,attack_simulation,</group>
  </rule>

  <rule id="100402" level="10">
    <program_name>^lab4-ransomware$</program_name>
    <match>ENCRYPT:COMPLETE</match>
    <description>Lab 4 Sim: Ransomware encryption complete — files locked</description>
    <mitre>
      <id>T1486</id>
    </mitre>
    <group>lab4,ransomware,impact,attack_simulation,</group>
  </rule>

  <rule id="100403" level="10">
    <program_name>^lab4-ransomware$</program_name>
    <match>RANSOM</match>
    <description>Lab 4 Sim: Ransom note dropped to filesystem</description>
    <mitre>
      <id>T1491</id>
    </mitre>
    <group>lab4,ransomware,impact,attack_simulation,</group>
  </rule>

  <rule id="100404" level="12">
    <program_name>^lab4-ransomware$</program_name>
    <match>STAGE:INHIBIT</match>
    <description>Lab 4 Sim: Ransomware sweeping for backup files to destroy</description>
    <mitre>
      <id>T1490</id>
    </mitre>
    <group>lab4,ransomware,inhibit_recovery,attack_simulation,</group>
  </rule>

  <rule id="100405" level="12">
    <program_name>^lab4-ransomware$</program_name>
    <match>INHIBIT:FOUND_BACKUP</match>
    <description>Lab 4 Sim: Ransomware found backup file targeted for destruction</description>
    <mitre>
      <id>T1490</id>
    </mitre>
    <group>lab4,ransomware,inhibit_recovery,attack_simulation,</group>
  </rule>

  <!-- ── Lab 5: Supply chain sim ─────────────────────────────────────── -->

  <rule id="100500" level="7">
    <program_name>^lab5-supply-chain$</program_name>
    <match>STAGE:INSTALL</match>
    <description>Lab 5 Sim: Malicious package install initiated</description>
    <mitre>
      <id>T1195.001</id>
    </mitre>
    <group>lab5,supply_chain,attack_simulation,</group>
  </rule>

  <rule id="100501" level="8">
    <program_name>^lab5-supply-chain$</program_name>
    <match>INSTALL:HOOK</match>
    <description>Lab 5 Sim: Post-install hook executing in package setup.py</description>
    <mitre>
      <id>T1195.001</id>
    </mitre>
    <group>lab5,supply_chain,attack_simulation,</group>
  </rule>

  <rule id="100502" level="9">
    <program_name>^lab5-supply-chain$</program_name>
    <match>STAGE:DROPPER</match>
    <description>Lab 5 Sim: Payload dropper writing file to filesystem</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>lab5,supply_chain,attack_simulation,</group>
  </rule>

  <rule id="100503" level="9">
    <program_name>^lab5-supply-chain$</program_name>
    <match>DROPPER:WRITTEN</match>
    <description>Lab 5 Sim: Malicious payload written to disk</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>lab5,supply_chain,attack_simulation,</group>
  </rule>

  <rule id="100504" level="8">
    <program_name>^lab5-supply-chain$</program_name>
    <match>STAGE:CALLBACK</match>
    <description>Lab 5 Sim: Payload executing outbound C2 callback</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>lab5,supply_chain,c2,attack_simulation,</group>
  </rule>

  <rule id="100505" level="8">
    <program_name>^lab5-supply-chain$</program_name>
    <match>CALLBACK:BEACON_SENT</match>
    <description>Lab 5 Sim: C2 beacon sent — host phoned home</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>lab5,supply_chain,c2,attack_simulation,</group>
  </rule>

  <rule id="100506" level="10">
    <program_name>^lab5-supply-chain$</program_name>
    <match>STAGE:PERSIST</match>
    <description>Lab 5 Sim: Cron-based persistence being installed</description>
    <mitre>
      <id>T1053.003</id>
    </mitre>
    <group>lab5,supply_chain,persistence,attack_simulation,</group>
  </rule>

  <rule id="100507" level="12">
    <program_name>^lab5-supply-chain$</program_name>
    <match>PERSIST:CRON_INSTALLED</match>
    <description>Lab 5 Sim: Malicious cron entry installed for persistent execution</description>
    <mitre>
      <id>T1053.003</id>
    </mitre>
    <group>lab5,supply_chain,persistence,attack_simulation,</group>
  </rule>

  <!-- ── Lab 6: C2 beacon sim ──────────────────────────────────────────── -->

  <rule id="100600" level="5">
    <program_name>^lab6-c2-beacon$</program_name>
    <match>STAGE:IMPLANT_START</match>
    <description>Lab 6 Sim: C2 implant started — beaconing initiated</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>lab6,c2,attack_simulation,</group>
  </rule>

  <rule id="100601" level="5">
    <program_name>^lab6-c2-beacon$</program_name>
    <match>BEACON:</match>
    <description>Lab 6 Sim: C2 beacon sent to remote host</description>
    <mitre>
      <id>T1071.001</id>
      <id>T1573.001</id>
    </mitre>
    <group>lab6,c2,beacon,attack_simulation,</group>
  </rule>

  <rule id="100602" level="5">
    <program_name>^lab6-c2-beacon$</program_name>
    <match>BEACON_RESPONSE:</match>
    <description>Lab 6 Sim: C2 beacon HTTP response received</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>lab6,c2,beacon,attack_simulation,</group>
  </rule>

  <rule id="100603" level="6">
    <program_name>^lab6-c2-beacon$</program_name>
    <match>STAGE:IMPLANT_DONE</match>
    <description>Lab 6 Sim: C2 beacon sequence complete</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>lab6,c2,attack_simulation,</group>
  </rule>

  <!-- ── Lab 7: LLM key exfil sim ─────────────────────────────────────── -->

  <rule id="100700" level="6">
    <program_name>^lab7-key-exfil$</program_name>
    <match>STAGE:DISCOVERY</match>
    <description>Lab 7 Sim: Attacker scanning filesystem for AI credential files</description>
    <mitre>
      <id>T1552.001</id>
      <id>T1083</id>
    </mitre>
    <group>lab7,credential_access,discovery,attack_simulation,</group>
  </rule>

  <rule id="100701" level="6">
    <program_name>^lab7-key-exfil$</program_name>
    <match>DISCOVERY:COMPLETE</match>
    <description>Lab 7 Sim: Credential file discovery complete — candidate files found</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>lab7,credential_access,discovery,attack_simulation,</group>
  </rule>

  <rule id="100702" level="8">
    <program_name>^lab7-key-exfil$</program_name>
    <match>STAGE:EXTRACT</match>
    <description>Lab 7 Sim: Attacker reading credential file for key extraction</description>
    <mitre>
      <id>T1552.001</id>
    </mitre>
    <group>lab7,credential_access,attack_simulation,</group>
  </rule>

  <rule id="100703" level="8">
    <program_name>^lab7-key-exfil$</program_name>
    <match>EXTRACT:GREP</match>
    <description>Lab 7 Sim: Attacker grepping for AI API key prefixes in credential file</description>
    <mitre>
      <id>T1552.001</id>
    </mitre>
    <group>lab7,credential_access,attack_simulation,</group>
  </rule>

  <rule id="100704" level="10">
    <program_name>^lab7-key-exfil$</program_name>
    <match>EXTRACT:SUCCESS</match>
    <description>Lab 7 Sim: AI API key successfully extracted — exfiltration imminent</description>
    <mitre>
      <id>T1552.001</id>
    </mitre>
    <group>lab7,credential_access,attack_simulation,</group>
  </rule>

  <rule id="100705" level="12">
    <program_name>^lab7-key-exfil$</program_name>
    <match>STAGE:EXFIL</match>
    <description>Lab 7 Sim: AI API key being exfiltrated over HTTPS</description>
    <mitre>
      <id>T1041</id>
    </mitre>
    <group>lab7,exfiltration,attack_simulation,</group>
  </rule>

  <rule id="100706" level="12">
    <program_name>^lab7-key-exfil$</program_name>
    <match>EXFIL:COMPLETE</match>
    <description>Lab 7 Sim: API key exfiltration complete — data sent to C2</description>
    <mitre>
      <id>T1041</id>
    </mitre>
    <group>lab7,exfiltration,attack_simulation,</group>
  </rule>

  <rule id="100707" level="10">
    <program_name>^lab7-key-exfil$</program_name>
    <match>STAGE:VALIDATE</match>
    <description>Lab 7 Sim: Attacker testing stolen API key against provider endpoint</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>lab7,credential_access,attack_simulation,</group>
  </rule>

  <rule id="100708" level="10">
    <program_name>^lab7-key-exfil$</program_name>
    <match>VALIDATE:COMPLETE</match>
    <description>Lab 7 Sim: Stolen API key validation attempt complete</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>lab7,credential_access,attack_simulation,</group>
  </rule>

</group>
