# ── Fortark SOC Lab — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# Run setup.sh (macOS/Linux) or setup.ps1 (Windows) — it will auto-generate
# the secret values marked GENERATED below.

# ── OpenSearch ────────────────────────────────────────────────────────────
# Min 12 chars, must include uppercase, number, and special character
OPENSEARCH_ADMIN_PASSWORD=GENERATED

# ── Wazuh ─────────────────────────────────────────────────────────────────
WAZUH_API_USERNAME=wazuh-api-admin
WAZUH_API_PASSWORD=GENERATED

# ── TheHive ───────────────────────────────────────────────────────────────
THEHIVE_SECRET=GENERATED
# API key for the automation account — generated during first-run setup
THEHIVE_API_KEY=

# ── Cortex ────────────────────────────────────────────────────────────────
CORTEX_SECRET=GENERATED
# API key for the TheHive↔Cortex integration — generated during first-run setup
CORTEX_THEHIVE_API_KEY=

# Absolute path on your HOST machine for Cortex analyser job files.
# Docker Desktop must be able to bind-mount this path into sub-containers.
# macOS example:  /Users/yourname/fortark-soc-lab/platform/cortex/jobs
# Windows example: /c/Users/yourname/fortark-soc-lab/platform/cortex/jobs
CORTEX_JOBS_PATH=/Users/yourname/fortark-soc-lab/platform/cortex/jobs

# ── Shuffle ───────────────────────────────────────────────────────────────
SHUFFLE_ENCRYPTION_KEY=GENERATED
SHUFFLE_DEFAULT_USERNAME=admin
SHUFFLE_DEFAULT_PASSWORD=ChangeMe!Shuffle1

# ── Kali Desktop ──────────────────────────────────────────────────────────
KALI_VNC_PASSWORD=kalipassword

# ── External API Keys (self-service — create free accounts) ───────────────
# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Shodan: https://account.shodan.io/
SHODAN_API_KEY=
